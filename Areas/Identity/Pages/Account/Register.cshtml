@page
@model SnappersRepairShop.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Registration Not Available";
    Layout = "/Areas/Identity/Pages/_Layout.cshtml";
}

<div style="max-width: 500px; margin: 60px auto; text-align: center; font-family: 'Segoe UI', sans-serif;">
    <h2 style="margin-bottom: 16px;">Registration Not Available</h2>
    <p style="color: #666; margin-bottom: 24px;">
        Account registration is managed by your administrator.
        Please contact your shop administrator to have an account created for you.
    </p>
    <a href="/Identity/Account/Login"
       style="display: inline-block; padding: 10px 24px; background-color: #1976d2; color: white; text-decoration: none; border-radius: 4px;">
        Back to Login
    </a>
</div>
