@using Microsoft.AspNetCore.Components.Web
@inherits ErrorBoundary
@inject ILogger<AppErrorBoundary> Logger

@if (CurrentException is null)
{
    @ChildContent
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
        <MudPaper Elevation="3" Class="pa-6">
            <MudStack Spacing="4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
                    <MudText Typo="Typo.h5" Color="Color.Error">An Error Occurred</MudText>
                </MudStack>

                <MudDivider />

                <MudText Typo="Typo.body1">
                    We're sorry, but something went wrong. The error has been logged and our team will investigate.
                </MudText>

                @if (ShowDetails)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                        <MudText Typo="Typo.body2" Style="font-family: monospace; white-space: pre-wrap;">
                            @CurrentException.Message
                        </MudText>
                    </MudAlert>

                    @if (!string.IsNullOrEmpty(CurrentException.StackTrace))
                    {
                        <MudExpansionPanels>
                            <MudExpansionPanel Text="Stack Trace">
                                <MudText Typo="Typo.caption" Style="font-family: monospace; white-space: pre-wrap; font-size: 0.75rem;">
                                    @CurrentException.StackTrace
                                </MudText>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }
                }

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                               OnClick="Recover" StartIcon="@Icons.Material.Filled.Refresh">
                        Try Again
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" 
                               Href="/" StartIcon="@Icons.Material.Filled.Home">
                        Go to Dashboard
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudContainer>
}

@code {
    [Parameter]
    public bool ShowDetails { get; set; } = false;

    protected override Task OnErrorAsync(Exception exception)
    {
        Logger.LogError(exception, "Error boundary caught an exception");
        return base.OnErrorAsync(exception);
    }
}

